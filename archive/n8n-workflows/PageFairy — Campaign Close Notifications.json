      "id": "cc-03-patch-successful",
      "name": "Set Campaign Successful",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        688,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Campaign Closed Webhook').first().json.body;\nconst retail = parseFloat(d.retail_price ?? 0);\nconst wholesale = parseFloat(d.wholesale_cost ?? 0);\nconst goal = parseInt(d.goal_units ?? 0);\nconst totalRevenue = (goal * retail).toFixed(2);\nconst totalProfit = (goal * (retail - wholesale)).toFixed(2);\n\nconst message = `🎊 *GOAL REACHED!*\n\nYour '${d.campaign_name}' campaign hit ${goal} orders!\n\nTotal revenue: $${totalRevenue}\nYour profit: $${totalProfit}\n\nWe're now capturing payments and preparing to ship.\nYou'll receive your payout within 3-5 business days!`;\n\nreturn [{\n  json: {\n    chat_id: d.tech_chat_id,\n    message,\n    inline_keyboard: [[{\n      text: 'View Details 📊',\n      callback_data: `view_campaign_${d.campaign_id}`\n    }, {\n      text: 'Start New Campaign ➕',\n      callback_data: 'start_campaign'\n    }]]\n  }\n}];"
      },
      "id": "cc-04-build-success-msg",
      "name": "Build Goal Met Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        912,
        192
      ]
    },
