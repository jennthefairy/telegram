      "id": "cc-06-patch-failed",
      "name": "Set Campaign Failed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        688,
        432
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $('Campaign Closed Webhook').first().json.body;\nconst current = parseInt(d.current_units ?? 0);\nconst goal = parseInt(d.goal_units ?? 0);\n\nconst message = `Campaign ended — ${current}/${goal} orders.\n\nNo charges have been made to your customers.\n\n${current} people were interested — that's a warm audience!\nConsider launching again with a lower goal or different product.`;\n\nreturn [{\n  json: {\n    chat_id: d.tech_chat_id,\n    message,\n    inline_keyboard: [[{\n      text: '🔄 Try Again',\n      callback_data: 'start_campaign'\n    }, {\n      text: '👀 Browse Products',\n      callback_data: 'browse_products'\n    }]]\n  }\n}];"
      },
      "id": "cc-07-build-fail-msg",
